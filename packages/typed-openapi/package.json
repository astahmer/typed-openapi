{
  "name": "typed-openapi",
  "type": "module",
  "version": "3.0.0",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./node": "./dist/node.export.js",
    "./pretty": "./dist/pretty.export.js",
    "./runtimes": "./dist/runtimes.export.js",
    "./runtimes/zod": "./dist/runtimes/zod.export.js",
    "./runtimes/zod3": "./dist/runtimes/zod3.export.js",
    "./runtimes/effect": "./dist/runtimes/effect.export.js",
    "./runtimes/effect3": "./dist/runtimes/effect3.export.js",
    "./runtimes/valibot": "./dist/runtimes/valibot.export.js",
    "./runtimes/arktype": "./dist/runtimes/arktype.export.js",
    "./runtimes/typebox": "./dist/runtimes/typebox.export.js",
    "./runtimes/typia": "./dist/runtimes/typia.export.js"
  },
  "bin": {
    "typed-openapi": "bin.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/astahmer/typed-openapi.git",
    "directory": "packages/typed-openapi"
  },
  "scripts": {
    "start": "node ./dist/cli.js",
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "ATTEST_skipTypes=1 vitest",
    "test:unit": "TEST_UNIT=1 ATTEST_skipTypes=1 vitest run",
    "gen:runtime": "node bin.js ./tests/samples/petstore.yaml --output ./tmp/generated-client.ts --tanstack generated-tanstack.ts --default-fetcher",
    "gen:tstyche-fixtures": "tsx scripts/gen-tstyche-fixtures.ts && tsx scripts/gen-tstyche-suites.ts",
    "gen:fixtures": "pnpm run gen:runtime && pnpm run gen:tstyche-fixtures",
    "gen:tstyche-suites": "tsx scripts/gen-tstyche-suites.ts",
    "test:types": "pnpm run gen:fixtures && tstyche",
    "test:types:attest": "ATTEST_skipTypes=0 vitest run tests/attest-generated.types.test.ts",
    "test:bench:attest": "node scripts/run-attest-bench.mjs --benchErrorOnThresholdExceeded",
    "test:matrix:integration": "vitest run tests/integrations/runtime-client-matrix.test.ts",
    "test:matrix:typecheck": "vitest run tests/integrations/runtime-client-matrix.typecheck.test.ts",
    "test:runtime:run": "vitest run tests/integrations/runtime-msw.test.ts tests/integrations/effect-msw.test.ts",
    "test:runtime": "pnpm run gen:runtime && pnpm run test:runtime:run",
    "test:all": "node scripts/test-all.mjs",
    "fmt": "oxfmt --write src tests",
    "typecheck": "tsc -b ./tsconfig.build.json"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "12.1.0",
    "arktype": "2.2.3",
    "cac": "7.0.0",
    "openapi3-ts": "4.6.0",
    "oxfmt": "0.59.0",
    "pastable": "2.2.1",
    "pathe": "2.0.3",
    "ts-pattern": "5.9.0",
    "tsx": "4.23.1"
  },
  "peerDependencies": {
    "@effect/schema": "0.75.5",
    "@sinclair/typebox": "0.34.52",
    "arktype": "2.2.3",
    "effect": "4.0.0-beta.100",
    "typia": "13.1.19",
    "valibot": "1.4.2",
    "zod": "3.25.76 || 4.4.3"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "effect": {
      "optional": true
    },
    "@effect/schema": {
      "optional": true
    },
    "valibot": {
      "optional": true
    },
    "arktype": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    },
    "typia": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ark/attest": "0.56.3",
    "@changesets/cli": "2.31.1",
    "@effect/schema": "0.75.5",
    "@sinclair/typebox": "0.34.52",
    "@tanstack/react-query": "5.101.3",
    "@types/node": "24.13.3",
    "effect": "4.0.0-beta.100",
    "msw": "2.15.0",
    "openapi-types": "12.1.3",
    "tstyche": "7.2.2",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typia": "13.1.19",
    "valibot": "1.4.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  },
  "files": [
    "src",
    "dist",
    "cli",
    "README.md"
  ],
  "keywords": [
    "typescript",
    "openapi",
    "generator",
    "runtime",
    "typesafe",
    "zod",
    "effect",
    "arktype",
    "valibot",
    "typebox",
    "typia"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
