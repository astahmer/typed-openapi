{
  "name": "typed-openapi",
  "type": "module",
  "version": "3.0.0",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./node": "./dist/node.export.js",
    "./pretty": "./dist/pretty.export.js",
    "./runtimes": "./dist/runtimes.export.js",
    "./runtimes/zod": "./dist/runtimes/zod.export.js",
    "./runtimes/zod3": "./dist/runtimes/zod3.export.js",
    "./runtimes/effect": "./dist/runtimes/effect.export.js",
    "./runtimes/effect3": "./dist/runtimes/effect3.export.js",
    "./runtimes/valibot": "./dist/runtimes/valibot.export.js",
    "./runtimes/arktype": "./dist/runtimes/arktype.export.js"
  },
  "bin": {
    "typed-openapi": "bin.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/astahmer/typed-openapi.git",
    "directory": "packages/typed-openapi"
  },
  "scripts": {
    "start": "node ./dist/cli.js",
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:types": "tsx scripts/gen-effect-client-fixture.ts && tstyche",
    "gen:runtime": "node bin.js ./tests/samples/petstore.yaml --output ./tmp/generated-client.ts --tanstack generated-tanstack.ts --default-fetcher",
    "test:runtime:run": "vitest run tests/integration-runtime-msw.test.ts",
    "test:runtime": "pnpm run gen:runtime && pnpm run test:runtime:run",
    "fmt": "oxfmt --write src tests",
    "typecheck": "tsc -b ./tsconfig.build.json"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "12.1.0",
    "arktype": "2.2.3",
    "cac": "7.0.0",
    "openapi3-ts": "4.6.0",
    "oxfmt": "0.59.0",
    "pastable": "2.2.1",
    "pathe": "2.0.3",
    "ts-pattern": "5.9.0"
  },
  "peerDependencies": {
    "zod": "3.25.76 || 4.4.3",
    "effect": "3.22.0",
    "@effect/schema": "0.75.5",
    "valibot": "1.4.2",
    "arktype": "2.2.3"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "effect": {
      "optional": true
    },
    "@effect/schema": {
      "optional": true
    },
    "valibot": {
      "optional": true
    },
    "arktype": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@effect/schema": "0.75.5",
    "@tanstack/react-query": "5.101.3",
    "@types/node": "25.6.0",
    "effect": "3.22.0",
    "msw": "2.15.0",
    "tstyche": "7.2.2",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "valibot": "1.4.2",
    "vite": "7.3.6",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  },
  "files": [
    "src",
    "dist",
    "cli",
    "README.md"
  ],
  "keywords": [
    "typescript",
    "openapi",
    "generator",
    "runtime",
    "typesafe",
    "zod",
    "effect",
    "arktype",
    "valibot"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
