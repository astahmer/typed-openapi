{
  "name": "typed-openapi-monorepo",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/astahmer/typed-openapi.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter typed-openapi build",
    "build:all": "pnpm -r run build",
    "fmt": "oxfmt",
    "release": "changeset publish",
    "release-dev": "changeset version --snapshot dev && changeset publish --tag dev",
    "test": "TEST_UNIT=true pnpm --filter typed-openapi test",
    "test:all": "pnpm --filter typed-openapi test:all"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "oxfmt": "0.59.0"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
