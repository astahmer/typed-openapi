<section class="snippet-builder" data-command-builder aria-labelledby="snippet-builder-title">
  <div class="snippet-builder-copy">
    <p class="home-eyebrow">Generate a starting point</p>
    <h2 id="snippet-builder-title">Pick the files you want to own.</h2>
    <p>Start with a local spec or a pinned public URL. The command below is ready to paste, then keep the generated files in your repository.</p>
  </div>

  <div class="snippet-builder-controls">
    <label>
      <span>OpenAPI input</span>
      <select data-input aria-label="OpenAPI input">
        <option value="./openapi.yaml">Local file</option>
        <option value="https://raw.githubusercontent.com/cloudflare/api-schemas/82dba40b10f6b6db23b2ea57bb370bdbfceeaa1a/openapi.json">
          Cloudflare OpenAPI URL
        </option>
      </select>
    </label>
    <label>
      <span>Runtime</span>
      <select data-runtime aria-label="Runtime">
        <option value="none">Types only</option>
        <option value="zod">Zod</option>
        <option value="valibot">Valibot</option>
        <option value="effect">Effect</option>
      </select>
    </label>
    <label>
      <span>Transport</span>
      <select data-transport aria-label="Transport">
        <option value="fetch">Generated Fetch client</option>
        <option value="headless">Bring your own fetcher</option>
      </select>
    </label>
  </div>

  <div class="snippet-builder-command">
    <code data-command></code>
    <button type="button" data-copy>Copy</button>
  </div>
  <p class="snippet-builder-output">Writes <span data-files></span>. The Cloudflare option uses its raw, pinned GitHub file.</p>
</section>

<script>
  for (const builder of document.querySelectorAll("[data-command-builder]")) {
    const input = builder.querySelector("[data-input]");
    const runtime = builder.querySelector("[data-runtime]");
    const transport = builder.querySelector("[data-transport]");
    const command = builder.querySelector("[data-command]");
    const copy = builder.querySelector("[data-copy]");
    const files = builder.querySelector("[data-files]");

    if (!(input instanceof HTMLSelectElement) || !(runtime instanceof HTMLSelectElement) || !(transport instanceof HTMLSelectElement) || !(command instanceof HTMLElement) || !(copy instanceof HTMLButtonElement) || !(files instanceof HTMLElement)) continue;

    const update = () => {
      const runtimeFlag = runtime.value === "none" ? "" : ` --runtime ${runtime.value}`;
      const name = runtime.value === "none" ? "openapi.client" : `openapi.${runtime.value}`;
      const fetcherFlag = transport.value === "fetch" ? " --default-fetcher" : "";
      const outputFiles = [`src/api/${name}.ts`];
      if (runtime.value !== "none") outputFiles.push(`src/api/${name}.types.d.ts`);
      if (transport.value === "fetch") outputFiles.push("src/api/api.client.ts");
      command.textContent = `pnpm exec typed-openapi ${input.value} --output src/api/${name}.ts${runtimeFlag}${fetcherFlag} --format`;
      files.textContent = outputFiles.join(" · ");
    };

    input.addEventListener("change", update);
    runtime.addEventListener("change", update);
    transport.addEventListener("change", update);
    copy.addEventListener("click", async () => {
      await navigator.clipboard.writeText(command.textContent ?? "");
      copy.textContent = "Copied";
      window.setTimeout(() => {
        copy.textContent = "Copy";
      }, 1_200);
    });
    update();
  }
</script>
