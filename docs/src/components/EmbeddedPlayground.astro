---
const playgroundUrl = `${import.meta.env.BASE_URL}playground/app/index.html`;
---

<div class="playground-frame">
  <iframe
    data-playground-frame
    title="typed-openapi playground"
    src={playgroundUrl}
    loading="eager"
    allow="clipboard-read; clipboard-write"
  ></iframe>
</div>

<p class="playground-frame-actions">
  <a data-playground-fullscreen href={playgroundUrl} target="_blank" rel="noreferrer">Open the playground full screen ↗</a>
</p>

<script>
  const frame = document.querySelector<HTMLIFrameElement>("[data-playground-frame]");
  const fullscreen = document.querySelector<HTMLAnchorElement>("[data-playground-fullscreen]");

  if (frame && window.location.search) {
    const url = new URL(frame.src);
    url.search = window.location.search;
    frame.src = url.href;

    if (fullscreen) fullscreen.href = url.href;
  }
</script>
